{
  "name": "@strudel/monorepo",
  "version": "0.6.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "cd website && pnpm dev",
    "build": "cd website && pnpm build",
    "preview": "cd website && pnpm preview",
    "test": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "tsc --noEmit",
    "prepare": "husky install",
    "jsdoc": "jsdoc packages/ -c jsdoc/jsdoc.config.json",
    "jsdoc-json": "jsdoc packages/ --template ./node_modules/jsdoc-json --destination doc.json -c jsdoc/jsdoc.config.json"
  },
  "devDependencies": {
    "@types/node": "^20.19.6",
    "@typescript-eslint/eslint-plugin": "^6.21.0",
    "@typescript-eslint/parser": "^6.21.0",
    "@vitest/coverage-v8": "^1.6.1",
    "debug": "^4.4.1",
    "eslint": "^8.57.1",
    "husky": "^8.0.3",
    "jsdoc": "^4.0.4",
    "jsdoc-json": "^2.0.2",
    "lint-staged": "^15.5.2",
    "prettier": "^3.6.2",
    "typescript": "^5.8.3",
    "vitest": "^1.6.1"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,yml}": [
      "prettier --write"
    ]
  },
  "workspaces": [
    "packages/*",
    "website"
  ]
}