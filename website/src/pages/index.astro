---
import MainLayout from '../layouts/MainLayout.astro';
---

<MainLayout>
  <div class="container mx-auto px-4 py-8">
    <h1 class="text-4xl font-bold mb-4">Welcome to Strudel</h1>
    <p class="text-lg mb-4">
      A live coding environment for the browser, powered by JavaScript and Web Audio.
    </p>
    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
      <div class="bg-white p-6 rounded-lg shadow-md">
        <h2 class="text-2xl font-semibold mb-3">Get Started</h2>
        <p>Start making music right in your browser with Strudel's live coding environment.</p>
      </div>
      <div class="bg-white p-6 rounded-lg shadow-md">
        <h2 class="text-2xl font-semibold mb-3">Learn More</h2>
        <p>Explore our documentation and tutorials to learn how to use Strudel.</p>
      </div>
    </div>
  </div>
</MainLayout> 